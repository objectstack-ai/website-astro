---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { type Lang } from '../lib/site';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  bodyClass?: string;
}

const {
  lang,
  title,
  description = 'ObjectStack is an AI-native application development platform and ObjectOS is the runtime platform where applications can interact with AI.',
  bodyClass = '',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://www.objectstack.ai');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <link rel="alternate" hreflang="en" href={Astro.url.pathname.replace(/^\/(en|zh-Hans|zh-Hant)/, '/en')} />
    <link rel="alternate" hreflang="zh-Hans" href={Astro.url.pathname.replace(/^\/(en|zh-Hans|zh-Hant)/, '/zh-Hans')} />
    <link rel="alternate" hreflang="zh-Hant" href={Astro.url.pathname.replace(/^\/(en|zh-Hans|zh-Hant)/, '/zh-Hant')} />
    <link rel="alternate" hreflang="x-default" href={Astro.url.pathname.replace(/^\/(en|zh-Hans|zh-Hant)/, '/en')} />
    <link rel="icon" href="/logo.svg" />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <SiteHeader lang={lang} />
    <main>
      <slot />
    </main>
    <SiteFooter lang={lang} />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #141917;
    --ink-soft: #2c3531;
    --muted: #62716b;
    --subtle: #94a19b;
    --paper: #f4f6f1;
    --paper-2: #e9efe7;
    --panel: #ffffff;
    --panel-2: #fbfcf8;
    --line: #dbe4da;
    --line-strong: #b4c4b8;
    --accent: #0a725f;
    --accent-strong: #064f43;
    --acid: #d7ee68;
    --amber: #c7902c;
    --blue: #416f86;
    --rose: #b35b57;
    --shadow: 0 24px 68px rgba(28, 48, 41, 0.09);
    --tight-shadow: 0 10px 28px rgba(28, 48, 41, 0.07);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(180deg, rgba(233, 239, 231, 0.78), transparent 25rem),
      var(--paper);
    color: var(--ink);
    font-family:
      Aptos, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", ui-sans-serif,
      system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    line-height: 1.56;
    letter-spacing: 0;
  }

  body::before {
    position: fixed;
    z-index: -1;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(8, 116, 95, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(8, 116, 95, 0.02) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.42), transparent 58%);
    content: "";
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    max-width: 100%;
  }

  main {
    overflow: hidden;
  }

  .container {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 14px;
    color: var(--accent-strong);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--accent);
    content: "";
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 980px;
    margin-bottom: 22px;
    font-size: clamp(2.65rem, 5.8vw, 5.05rem);
    font-weight: 780;
    line-height: 1.02;
    letter-spacing: 0;
  }

  html[lang^="zh"] h1 {
    font-size: clamp(2.45rem, 5vw, 4.45rem);
    line-height: 1.08;
  }

  h2 {
    max-width: 820px;
    margin-bottom: 18px;
    font-size: clamp(1.95rem, 3.25vw, 2.9rem);
    font-weight: 760;
    line-height: 1.08;
    letter-spacing: 0;
  }

  h3 {
    font-size: 1.16rem;
    font-weight: 740;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .lead {
    max-width: 760px;
    color: var(--muted);
    font-size: clamp(1.02rem, 1.8vw, 1.2rem);
  }

  .section {
    padding: 82px 0;
    border-top: 1px solid rgba(23, 24, 18, 0.08);
  }

  .grid {
    display: grid;
    gap: 18px;
  }

  .grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .grid.four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .card {
    min-height: 100%;
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.74)),
      var(--panel);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.8) inset;
    padding: 26px;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .card:hover {
    border-color: var(--line-strong);
    box-shadow: var(--tight-shadow);
    transform: translateY(-2px);
  }

  .card p {
    color: var(--muted);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: 8px;
    padding: 10px 17px;
    background: var(--ink);
    color: #fffdf7;
    font-weight: 720;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      background-color 160ms ease;
  }

  .button.secondary {
    border-color: var(--line);
    background: var(--panel);
    color: var(--ink);
  }

  .button:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(35, 55, 48, 0.14);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
    margin: 18px 0 0;
    list-style: none;
  }

  .tag-list li,
  .tag {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 10px;
    background: var(--panel-2);
    color: var(--muted);
    font-size: 0.84rem;
  }

  .code-panel {
    overflow: auto;
    border: 1px solid #202522;
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(215, 238, 104, 0.05), transparent 38%),
      #151917;
    color: #edf5e7;
    padding: 22px;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.88rem;
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .band {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.2)),
      var(--paper-2);
  }

  @media (max-width: 860px) {
    .container {
      width: min(100% - 28px, 1160px);
    }

    .grid.two,
    .grid.three,
    .grid.four {
      grid-template-columns: 1fr;
    }

    .section {
      padding: 62px 0;
    }

    h1 {
      font-size: clamp(2.75rem, 16vw, 4.4rem);
    }
  }
</style>
