<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>ObjectStack</title>
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="alternate" hreflang="zh-Hans" href="/zh-Hans/" />
    <link rel="alternate" hreflang="zh-Hant" href="/zh-Hant/" />
    <link rel="alternate" hreflang="x-default" href="/en/" />
    <script is:inline>
      (function () {
        try {
          var ok = ['en', 'zh-Hans', 'zh-Hant'];
          var saved = localStorage.getItem('preferred-lang');
          var lang;
          if (saved && ok.indexOf(saved) !== -1) {
            lang = saved;
          } else {
            var nav = (navigator.language || '').toLowerCase();
            lang = nav.indexOf('zh') === 0 ? (/hant|tw|hk|mo/.test(nav) ? 'zh-Hant' : 'zh-Hans') : 'en';
          }
          location.replace('/' + lang + '/');
        } catch (e) {
          location.replace('/en/');
        }
      })();
    </script>
    <meta http-equiv="refresh" content="0; url=/en/" />
  </head>
  <body>
    <p>Redirecting... <a href="/en/">English</a> · <a href="/zh-Hans/">简体中文</a> · <a href="/zh-Hant/">繁體中文</a></p>
  </body>
</html>
