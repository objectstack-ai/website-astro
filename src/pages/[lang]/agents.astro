---
import Base from '../../layouts/Base.astro';
import { isChinese, languages, pathFor, zhText, type Lang } from '../../lib/site';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const copy = isChinese(lang)
  ? {
      eyebrow: 'AI Development',
      title: zhText(lang, '用 AI 开发应用，并让应用安全地和 AI 交互。'),
      lead: zhText(lang, 'ObjectStack 是 AI 原生应用开发平台：开发者可以从源码或在线工作区使用 AI 构建应用。ObjectOS 是 AI 原生应用运行平台：每个应用都可以通过受治理动作和 MCP 工具与 AI 交互，而不是把原始 SQL 或屏幕控制权交给 Agent。'),
      primary: zhText(lang, '开始构建'),
      secondary: zhText(lang, '查看 ObjectStack'),
      blocks: [
        [zhText(lang, '应用模型即上下文'), zhText(lang, '对象、字段、关系、权限、视图和动作保持结构化，让 AI Coding Agent 能端到端理解应用。')],
        [zhText(lang, '动作即 AI 交互'), zhText(lang, '经过批准的应用动作可以生成 MCP tools，让 AI 调用真实业务能力，而不是绕过应用操作数据库。')],
        [zhText(lang, 'ObjectOS 即运行护栏'), zhText(lang, 'ObjectOS 在每次人类或 AI 调用时执行 RBAC、RLS、FLS、租户隔离、审计和请求归因。')],
      ],
      sections: [
        ['metadata-context', 'Metadata as Context', zhText(lang, '企业应用通常把意图散落在源码、SQL、表单、路由和权限里。ObjectStack 把应用模型压缩为 typed metadata，让 AI 能理解对象、策略、视图、动作和工具边界。')],
        ['mcp-tools', 'MCP Tools', zhText(lang, 'ObjectStack 可以把应用动作和查询表面暴露为 MCP tools。工具输入来自同一份 schema，执行经过 ObjectOS 权限检查，并留下审计日志。')],
        ['guardrails', 'Guardrails', zhText(lang, 'AI 继承用户身份和权限，不绕过应用系统。ObjectOS 统一处理租户、字段脱敏、审批、审计和策略。')],
      ],
    }
  : {
      eyebrow: 'AI Development',
      title: 'Build applications with AI, then let applications interact with AI safely.',
      lead: 'ObjectStack is the AI-native application development platform: developers build from source code or online workspaces with AI assistance. ObjectOS is the AI-native runtime platform: every application can interact with AI through governed actions and MCP tools instead of giving agents raw SQL or screen control.',
      primary: 'Start Building',
      secondary: 'View ObjectStack',
      blocks: [
        ['The app model becomes context', 'Objects, fields, relationships, permissions, views, and actions stay structured enough for AI coding agents to understand the application end to end.'],
        ['Actions become AI interaction', 'Approved application actions become MCP tools, letting AI call real business capabilities without bypassing the application or touching storage directly.'],
        ['ObjectOS becomes runtime guardrails', 'ObjectOS enforces RBAC, RLS, FLS, tenant isolation, audit, and request attribution on every human or AI call.'],
      ],
      sections: [
        ['metadata-context', 'Metadata as Context', 'Enterprise apps scatter intent across source code, SQL, forms, routes, and permissions. ObjectStack compresses the application model into typed metadata so AI can understand objects, policies, views, actions, and tool boundaries in context.'],
        ['mcp-tools', 'MCP Tools', 'ObjectStack can expose application actions and query surfaces as MCP tools. Tool inputs come from the same schema, execution passes through ObjectOS permissions, and every invocation leaves an audit trail.'],
        ['guardrails', 'Guardrails', 'AI inherits user identity and permissions instead of bypassing the app. ObjectOS handles tenancy, field redaction, approvals, audit, and policy enforcement consistently.'],
      ],
    };
---

<Base lang={lang} title={`${copy.eyebrow} | ObjectStack`} description={copy.lead}>
  <section class="agents-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{copy.eyebrow}</p>
        <h1>{copy.title}</h1>
        <p class="lead">{copy.lead}</p>
        <div class="button-row">
          <a class="button" href={pathFor(lang, '/cloud')}>{copy.primary}</a>
          <a class="button secondary" href={pathFor(lang, '/objectstack')}>{copy.secondary}</a>
        </div>
      </div>
      <aside class="tool-surface" aria-label="MCP tool surface">
        <span>mcp.tool.customer.update</span>
        <pre>{`{
  "input": "typed schema",
  "identity": "current user",
  "policy": "runtime enforced",
  "audit": "request scoped"
}`}</pre>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container block-grid">
      {copy.blocks.map(([title, text]) => (
        <article class="card">
          <h2>{title}</h2>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section band">
    <div class="container detail-list">
      {copy.sections.map(([id, title, text]) => (
        <article id={id}>
          <span>{id}</span>
          <h2>{title}</h2>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .agents-hero {
    padding: 92px 0 72px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 48px;
    align-items: center;
  }

  .tool-surface {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #151a18;
    box-shadow: var(--shadow);
    color: #f7f8f4;
    padding: 24px;
  }

  .tool-surface span {
    color: var(--acid);
    font-size: 0.86rem;
    font-weight: 760;
  }

  .tool-surface pre {
    overflow: auto;
    margin: 24px 0 0;
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 0.9rem;
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .block-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .block-grid h2 {
    font-size: 1.35rem;
  }

  .detail-list {
    display: grid;
    gap: 16px;
  }

  .detail-list article {
    display: grid;
    grid-template-columns: 190px minmax(220px, 0.45fr) minmax(0, 1fr);
    gap: 28px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    padding: 24px;
  }

  .detail-list span {
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 780;
  }

  .detail-list h2 {
    margin: 0;
    font-size: 1.45rem;
  }

  .detail-list p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .hero-grid,
    .block-grid,
    .detail-list article {
      grid-template-columns: 1fr;
    }
  }
</style>
