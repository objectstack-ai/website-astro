---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { formatDate, isChinese, languages, splitBlogId, zhText, type Lang } from '../../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((entry) => entry.id !== 'index' && !!entry.data.date)
    .map((entry) => {
      const { lang, slug } = splitBlogId(entry.id);
      return { params: { lang, slug }, props: { entry } };
    })
    .filter((route) => languages.includes(route.params.lang as Lang));
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const { Content } = await render(entry);
---

<Base lang={lang} title={`${entry.data.title} | ObjectStack Blog`} description={entry.data.description}>
  <article class="article">
    <header class="article-header">
      <div class="container article-head-grid">
        <aside class="article-meta">
          <a class="back-link" href={`/${lang}/blog`}>{isChinese(lang) ? zhText(lang, '返回博客') : 'Back to blog'}</a>
          <time>{formatDate(entry.data.date, lang)}</time>
          <ul class="tag-list">
            {entry.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </aside>
        <div>
          <p class="eyebrow">ObjectStack Journal</p>
          <h1>{entry.data.title}</h1>
          <p class="lead">{entry.data.description}</p>
        </div>
      </div>
    </header>
    <div class="container article-body">
      <Content />
    </div>
  </article>
</Base>

<style>
  .article-header {
    padding: 84px 0 60px;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(135deg, rgba(217, 243, 106, 0.28), transparent 38%),
      var(--paper-2);
  }

  .article-head-grid {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 46px;
    align-items: start;
  }

  .article-header h1 {
    max-width: 920px;
    font-size: clamp(2.8rem, 6.8vw, 5.9rem);
    line-height: 0.98;
  }

  .article-meta {
    position: sticky;
    top: 96px;
    border-top: 4px solid var(--ink);
    padding-top: 18px;
  }

  .back-link,
  time {
    display: block;
    margin-bottom: 18px;
    color: var(--accent-strong);
    font-family:
      ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-weight: 760;
  }

  .back-link {
    color: var(--ink);
  }

  .article-body {
    max-width: 800px;
    padding: 64px 0 96px;
    font-size: 1.13rem;
    line-height: 1.72;
  }

  .article-body :global(h2) {
    margin-top: 2.55rem;
    font-size: clamp(1.65rem, 3vw, 2.3rem);
    line-height: 1.12;
  }

  .article-body :global(h3) {
    margin-top: 2rem;
    font-size: 1.25rem;
  }

  .article-body :global(p),
  .article-body :global(li) {
    color: var(--muted);
  }

  .article-body :global(p:first-child) {
    color: var(--ink-soft);
    font-size: 1.2rem;
  }

  .article-body :global(a) {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-body :global(blockquote) {
    margin: 2rem 0;
    border-left: 4px solid var(--accent);
    padding-left: 18px;
    color: var(--ink);
    font-size: 1.24rem;
    line-height: 1.5;
  }

  .article-body :global(pre) {
    overflow: auto;
    border-radius: 8px;
    background: #171812;
    color: #edf5e7;
    padding: 18px;
  }

  @media (max-width: 860px) {
    .article-head-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .article-meta {
      position: static;
    }
  }
</style>
