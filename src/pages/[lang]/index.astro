---
import Base from '../../layouts/Base.astro';
import { getDict, languages, pathFor, titledBlocks, type Lang } from '../../lib/site';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const dict = getDict(lang);
const products = [
  dict.ecosystem.protocol,
  dict.ecosystem.runtime,
  dict.ecosystem.view,
];
const features = titledBlocks(dict.features);
const useCases = titledBlocks(dict.useCases).filter((item) => item.description);
const faqs: any[] = dict.faq.items ?? [];
---

<Base lang={lang} title="ObjectStack | AI-Native Business Framework" description={dict.hero.description}>
  <section class="home-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{dict.hero.comingSoon}</p>
        <h1>{dict.hero.title} <span>{dict.hero.titleHighlight}</span></h1>
        <p class="lead">{dict.hero.description}</p>
        <div class="button-row">
          <a class="button" href="https://github.com/objectstack-ai/framework">{dict.hero.ctaPrimary}</a>
          <a class="button secondary" href="https://tally.so/r/2EeW0V">{dict.hero.ctaSecondary}</a>
        </div>
      </div>
      <aside class="artifact" aria-label="ObjectStack metadata preview">
        <div class="artifact-top">
          <span>objectstack.ai</span>
          <span>{dict.hero.launchDate}</span>
        </div>
        <pre>{dict.howItWorks.step1.code}</pre>
      </aside>
    </div>
  </section>

  <section class="section band">
    <div class="container split">
      <div>
        <p class="eyebrow">{dict.builtForAi.eyebrow}</p>
        <h2>{dict.builtForAi.title}</h2>
        <p class="lead">{dict.builtForAi.lead}</p>
      </div>
      <div class="metric-grid">
        <div class="metric">
          <span>{dict.builtForAi.statBeforeLabel}</span>
          <strong>{dict.builtForAi.statBeforeValue}</strong>
          <small>{dict.builtForAi.statBeforeMeta}</small>
        </div>
        <div class="metric accent">
          <span>{dict.builtForAi.statAfterLabel}</span>
          <strong>{dict.builtForAi.statAfterValue}</strong>
          <small>{dict.builtForAi.statAfterMeta}</small>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Stack</p>
      <h2>{dict.ecosystem.title}</h2>
      <p class="lead">{dict.ecosystem.subtitle}</p>
      <div class="grid three product-triad">
        {products.map((product, index) => (
          <a class={`card product-${index}`} href={pathFor(lang, index === 0 ? '/objectstack' : index === 1 ? '/objectos' : '/objectui')}>
            <span>{product.label}</span>
            <h3>{product.name}</h3>
            <p>{product.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{dict.features.title}</h2>
      <p class="lead">{dict.features.subtitle}</p>
      <div class="grid three">
        {features.map((feature) => (
          <article class="card">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <h2>{dict.howItWorks.title}</h2>
      <p class="lead">{dict.howItWorks.subtitle}</p>
      <div class="grid three steps">
        {[dict.howItWorks.step1, dict.howItWorks.step2, dict.howItWorks.step3].map((step, index) => (
          <article class="card">
            <span class="step-index">0{index + 1}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{dict.useCases.title}</h2>
      <p class="lead">{dict.useCases.subtitle}</p>
      <div class="grid two">
        {useCases.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            {item.stats && <span class="tag">{item.stats}</span>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <h2>{dict.faq.title}</h2>
      <p class="lead">{dict.faq.subtitle}</p>
      <div class="faq-list">
        {faqs.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container">
      <p class="eyebrow">{dict.cta.badge}</p>
      <h2>{dict.cta.headline1}<br />{dict.cta.headline2}</h2>
      <p class="lead">{dict.cta.description}</p>
      <div class="button-row">
        <a class="button" href="https://tally.so/r/2EeW0V">{dict.cta.primaryButton}</a>
        <a class="button secondary" href="https://github.com/objectstack-ai/framework">{dict.cta.secondaryButton}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .home-hero {
    padding: 90px 0 80px;
  }

  .hero-grid,
  .split {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 36px;
    align-items: center;
  }

  h1 span {
    color: var(--accent-strong);
  }

  .artifact {
    overflow: hidden;
    border: 1px solid #202522;
    border-radius: 8px;
    background: #151716;
    box-shadow: var(--shadow);
    color: #edf5e7;
  }

  .artifact-top {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    padding: 12px 14px;
    color: rgba(255, 253, 247, 0.72);
    font-size: 0.8rem;
  }

  pre {
    overflow: auto;
    min-height: 420px;
    margin: 0;
    padding: 22px;
    font-size: 0.84rem;
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .metric-grid {
    display: grid;
    gap: 14px;
  }

  .metric {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 22px;
    background: var(--panel);
  }

  .metric span,
  .metric small {
    display: block;
    color: var(--muted);
  }

  .metric strong {
    display: block;
    margin: 8px 0;
    font-size: 2.7rem;
    line-height: 1;
  }

  .metric.accent {
    background: #dfeec1;
  }

  .product-triad .card {
    transition: transform 160ms ease, border-color 160ms ease;
  }

  .product-triad .card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
  }

  .product-triad span,
  .step-index {
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 820;
    text-transform: uppercase;
  }

  .faq-list {
    display: grid;
    gap: 10px;
    margin-top: 28px;
  }

  details {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    padding: 18px 20px;
  }

  summary {
    cursor: pointer;
    font-weight: 760;
  }

  details p {
    margin: 14px 0 0;
    color: var(--muted);
  }

  .final-cta {
    background: #dfeec1;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .split {
      grid-template-columns: 1fr;
    }
  }
</style>
