---
const target = '/zh-Hans';
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting to ObjectStack</title>
    <script is:inline>{`location.replace('/zh-Hans');`}</script>
  </head>
  <body>
    <a href={target}>Continue to ObjectStack</a>
  </body>
</html>
